// firestore.rules
// FIX #4 — Proper Firestore Security Rules.
//
// Key design decisions:
// - users: only the authenticated user can read/write their own document
// - startups: authenticated users can create; only the owner can update/delete
// - courseEnrollments: only created by authenticated backend (Cloud Functions use Admin SDK
//   which bypasses rules). Reads allowed only if the email matches or user is admin.
// - courses: read by anyone (public catalog); only admin can write

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    // A user can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Startups ─────────────────────────────────────────────────────────────
    // Any authenticated user can read startups (investor directory).
    // Only the owning user (uid matches ownerUid field) can update or delete.
    // Creation is allowed for authenticated users (ownerUid must match their uid).
    match /startups/{startupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerUid == request.auth.uid;
    }

    // ── Startup visit sub-collection ─────────────────────────────────────────
    // Investors (authenticated) can log visits; no one can read individual visits
    // from the client (analytics are aggregated server-side).
    match /startups/{startupId}/visits/{visitId} {
      allow create: if request.auth != null;
      allow read: if false; // only read via Admin SDK in Cloud Functions
    }

    // ── Courses ──────────────────────────────────────────────────────────────
    // Public read — anyone can browse the course catalog.
    // Writes are disallowed from the client; only manage via Firebase Console or Admin SDK.
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Course Enrollments ────────────────────────────────────────────────────
    // Created exclusively by the capturePayPalOrder Cloud Function (Admin SDK bypasses rules).
    // A logged-in user can read their own enrollments by UID.
    // Temporary fallback keeps legacy docs (without userId) readable by email.
    // No client-side writes allowed (prevents bypassing payment).
    match /courseEnrollments/{enrollmentId} {
      allow read: if request.auth != null
                  && (
                    resource.data.userId == request.auth.uid ||
                    (
                      !("userId" in resource.data) &&
                      resource.data.email == request.auth.token.email
                    )
                  );
      allow write: if false; // Cloud Functions Admin SDK bypasses this — intentional
    }
  }
}
